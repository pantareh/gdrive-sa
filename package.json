{
  "name": "@pantareh/mcp-gdrive-sa",
  "version": "1.1.0",
  "description": "MCP server for Google Drive using service account authentication",
  "type": "module",
  "bin": {
    "mcp-gdrive-sa": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && node scripts/e2e.mjs"
  },
  "keywords": [
    "mcp",
    "google-drive",
    "service-account",
    "claude",
    "ai",
    "modelcontextprotocol"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "googleapis": "^146.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
